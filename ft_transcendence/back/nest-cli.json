{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "plugins": [
      {
        "name": "@nestjs/swagger/plugin",
        "options": {
          "classValidatorShim": true
        }
      }
    ],
    "assets": [
      {
        "include": "i18n/**/*",
        "outDir": "dist",
        "watchAssets": true
      },
      {
        "include": "../public/**/*",
        "watchAssets": true,
        "outDir": "dist"
      }
    ]
  }
}
